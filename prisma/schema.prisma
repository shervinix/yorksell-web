generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // Profile / contact
  phone   String?
  company String?
  address String?

  // For credentials login
  passwordHash String?

  accounts Account[]
  sessions Session[]
  savedListings SavedListing[]
  leads Lead[]
  client Client?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Listing {
  id           String   @id @default(cuid())
  ddfId        String   @unique
  mlsNumber    String?
  status       String?
  addressLine  String?
  city         String?
  province     String?
  postalCode   String?
  lat          Float?
  lng          Float?
  price        Int?
  beds         Int?
  baths        Int?
  den          Int?   // number of dens / flex rooms
  sqft         Int?
  yearBuilt    Int?
  propertyType String?
  photoUrl     String?
  raw          Json
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([mlsNumber])
  @@index([status])
  @@index([city])
  @@index([propertyType])
  @@index([den])

  leads Lead[]
  savedListings SavedListing[]
}

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

model Lead {
  id         String    @id @default(cuid())
  email      String
  name       String?
  phone      String?
  message    String?
  source     String    // listing_contact | contact_page | home_cta
  listingId  String?
  userId     String?   // when submitted while logged in
  listing    Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([listingId])
  @@index([source])
  @@index([createdAt])
  @@index([userId])
}

model DdfSyncState {
  id          String    @id @default(cuid())
  name        String    @unique
  cursor      String?
  lastRunAt   DateTime?
  status      String?   // running | success | failed
  lastError   String?
  processed   Int?
  upserted    Int?
  errorCount  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Client {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  buyerClient               Boolean  @default(false)
  sellerClient              Boolean  @default(false)
  propertyManagementClient  Boolean  @default(false)
  showFiles                 Boolean  @default(true)
  showStats                 Boolean  @default(true)
  showNotes                 Boolean  @default(true)
  showUpdates               Boolean  @default(true)
  statsJson                 Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  files  ClientFile[]
  notes  ClientNote[]
  updates ClientUpdate[]

  @@index([userId])
}

model ClientFile {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  url       String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  content   String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model ClientUpdate {
  id        String   @id @default(cuid())
  clientId  String
  title     String
  content   String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model BlogPost {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  excerpt       String
  body          String
  coverImageUrl String?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
  @@index([publishedAt])
}
