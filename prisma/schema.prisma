generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // For credentials login
  passwordHash String?

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Listing {
  id           String   @id @default(cuid())
  ddfId        String   @unique
  mlsNumber    String?
  status       String?
  addressLine  String?
  city         String?
  province     String?
  postalCode   String?
  lat          Float?
  lng          Float?
  price        Int?
  beds         Int?
  baths        Int?
  sqft         Int?
  yearBuilt    Int?
  propertyType String?
  photoUrl     String?
  raw          Json
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([mlsNumber])
  @@index([status])
  @@index([city])
  @@index([propertyType])

  leads Lead[]
}

model Lead {
  id         String    @id @default(cuid())
  email      String
  name       String?
  phone      String?
  message    String?
  source     String    // listing_contact | contact_page | home_cta
  listingId  String?
  listing    Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([listingId])
  @@index([source])
  @@index([createdAt])
}

model DdfSyncState {
  id          String    @id @default(cuid())
  name        String    @unique
  cursor      String?
  lastRunAt   DateTime?
  status      String?   // running | success | failed
  lastError   String?
  processed   Int?
  upserted    Int?
  errorCount  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
